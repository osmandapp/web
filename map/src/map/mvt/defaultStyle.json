            "id": "background",
            "type": "background",
            "paint": { "background-color": "#f0e8d8" }
        },
        {
            "id": "landuse-residential",
            "type": "fill",
            "source": "osm",
            "source-layer": "ground_layer",
            "filter": ["all", ["==", "landuse", "residential"]],
            "paint": { "fill-color": "#e0d8d0" }
        },
        {
            "id": "landuse-commercial",
