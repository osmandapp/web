{
    "version": 8,
    "name": "default",
    "metadata": { "maputnik:renderer": "mlgljs" },
    "sources": {
        "osm": {
            "type": "vector",
            "tiles": ["https://test.osmand.net/vector/{z}/{x}/{y}.mvt"],
            "minzoom": 0,
            "maxzoom": 20,
            "buffer": 128
        }
    },
    "sprite": "/mvt/sprites/sprite",
    "glyphs": "/mvt/fonts/{fontstack}/{range}.pbf",
